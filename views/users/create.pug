extends ../layout 

block content
  .container.mt-5.mb-5
    .row.justify-content-center
      .col-md-6
        .card.shadow
          .card-body
            h2.text-center.mb-4 Registro de Usuario

            form(action="/users" method="POST" enctype="multipart/form-data")
              .mb-3
                label(for="name" class="form-label") Nombre
                input#name.form-control(type="text" name="name" required)

              .mb-3
                label(for="username" class="form-label") Username
                input#username.form-control(type="text" name="username" required)

              .mb-3
                label(for="password" class="form-label") Contraseña
                input#password.form-control(type="password" name="password" required)

              .mb-3
                label(for="email" class="form-label") Email
                input#email.form-control(type="email" name="email" required)

              .mb-3
                label(for="imagen" class="form-label") Imagen
                input#imagen.form-control(type="file" name="imagen")

              .mb-3
                label(for="rol" class="form-label") Rol
                input#rol.form-control(type="text" name="rol" required)

              button.btn.btn-primary.w-100(type="submit") Crear Usuario

block styles
  style.
    .card {
      border-radius: 10px;
      padding: 20px;
    }
    .form-label {
      font-weight: 500;
    }
    .btn-primary {
      background-color: #2e3a87;
      border-color: #2e3a87;
    }
    .btn-primary:hover {
      background-color: #1d2963;
      border-color: #1d2963;
    }
